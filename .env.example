# ================================================================
# Juggler LLM Gateway — Environment Configuration
# ================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your API keys (at least one provider is required)
# 3. Run:              docker-compose up -d
# ================================================================

# ----------------------------------------------------------------
# LLM Provider API Keys
# Add keys for every provider you want to route traffic to.
# You can enable one, two, or all three.
# ----------------------------------------------------------------

# Google Gemini
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic (Claude)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-4, GPT-3.5, etc.)
# Get your key: https://platform.openai.com/api-keys
# NOTE: OpenAI provider is on the roadmap. Adding the key here
# is forward-compatible — update config.yaml when ready.
OPENAI_API_KEY=

# ----------------------------------------------------------------
# Admin Dashboard Security
# ----------------------------------------------------------------

# Set a strong secret to protect the admin API.
# All /admin/v1/* endpoints require the header:
#   X-Admin-Key: <value>
#
# Leave as "changeme" or blank for open access (local dev only).
# Use a long random string in production:
#   openssl rand -hex 32
ADMIN_API_KEY=changeme

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------

# Gateway (Rust) log level: error | warn | info | debug | trace
RUST_LOG=info

# ----------------------------------------------------------------
# Internal Service Config (leave defaults unless you change ports)
# ----------------------------------------------------------------

# These are set automatically by docker-compose.
# Only override if you're running services manually (local dev).

# DATABASE_URL=postgres://juggler:password@localhost:5433/gateway_auth
# REDIS_URL=redis://localhost:6380
# CLICKHOUSE_ADDR=localhost:9000
# CLICKHOUSE_USER=juggler
# CLICKHOUSE_PASSWORD=password

# ----------------------------------------------------------------
# Kubernetes / Multi-Pod Scaling Config
# ----------------------------------------------------------------

# Postgres connections per gateway pod.
# Default: 5 (single host). For Kubernetes with PgBouncer:
#   MAX_DB_CONNECTIONS=3   (with 20+ pods, PgBouncer handles pooling)
# MAX_DB_CONNECTIONS=5

